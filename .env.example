# Tankstellen-IDs für fetch_petrol_data.py (Cron), kommagetrennt
STATION_IDS=993

# InfluxDB 3 Core – Verbindung
# Ohne TLS (lokal): http://192.168.178.52:8181
# Mit TLS (Cloud): https://eu-central-1-1.aws.cloud2.influxdata.com oder host:443
INFLUX_HOST=http://192.168.178.52:8181
INFLUX_TOKEN=dein-database-token
INFLUX_DATABASE=tankpreise

# Tabelle/Measurement und Spalten (Schema)
INFLUX_TABLE=tankpreise
INFLUX_TIME_COL=time
INFLUX_PRICE_COL=price
INFLUX_STATION_ID_COL=station_id
INFLUX_FUEL_TYPE_COL=fuel_type

# Ordnerstruktur: stations/<station_id>/<fuel_type>/ (z. B. stations/993/ARAL Ultimate 102/)
STATIONS_BASE_DIR=stations

# Training
LOOKBACK_HOURS=168
PREDICT_HORIZON_HOURS=24
# Standard-Historie beim Training in Stunden (default: 17520 = 2 Jahre)
DEFAULT_TRAINING_HOURS=17520
INFLUX_QUERY_FILE_LIMIT=2000